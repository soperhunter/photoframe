# Photo Frame — environment config
# Copy this to .env and adjust for your Pi setup.
# Never commit .env to git.

# Where photos and thumbnails are stored.
# Single-device default: on-disk next to the app.
# If you add a dedicated USB drive later, change this to /mnt/photos
PHOTOS_DIR=/opt/apps/photoframe/data/photos

# Port the FastAPI server binds to (Caddy proxies this)
PORT=8002

# Admin UI credentials (added in Phase 2)
# ADMIN_USER=admin
# ADMIN_PASSWORD=changeme
