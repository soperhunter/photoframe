# Photo Frame — environment config
# Copy this to .env and adjust for your Pi setup. Never commit .env to git.

# Where photos and thumbnails are stored.
# Single-device default: on-disk alongside the app.
# Point to /mnt/photos if you add a dedicated USB drive later.
PHOTOS_DIR=/opt/apps/photoframe/data/photos

# SQLite database location
DB_PATH=/opt/apps/photoframe/data/db.sqlite

# Port the FastAPI server binds to (Caddy proxies this)
PORT=8002

# Admin credentials — change these before putting the Pi on a network you don't trust
ADMIN_USER=admin
ADMIN_PASSWORD=changeme
